@model DriveNow.MVC.Models.AgenciaView

@{
    ViewData["Title"] = "Nova Agência";
}

<h2>Nova Agência</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="CriarAgencia" method="post">

    <div class="form-group">
        <label>Nome Fantasia</label>
        <input asp-for="NomeFantasia" class="form-control" />
        <span asp-validation-for="NomeFantasia" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>CEP</label>
        <input asp-for="Cep" class="form-control" />
        <span asp-validation-for="Cep" class="text-danger"></span>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>

</form>