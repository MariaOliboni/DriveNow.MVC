@model IEnumerable<DriveNow.MVC.Models.ClienteView>

<h1>Lista de Clientes</h1>

<p>
    <a class="btn btn-primary mb-3" asp-action="CriarCliente">Adicionar Cliente</a>
</p>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Email</th>
            <th>CPF</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>@item.Email</td>
                <td>@item.Cpf</td>
                <td>
                    <a asp-action="EditarCliente" asp-route-id="@item.Id" class="btn btn-warning">Editar</a>
                    <a asp-action="DeletarCliente" asp-route-id="@item.Id" class="btn btn-danger">Deletar</a>
                </td>
            </tr>
        }
    </tbody>
</table>