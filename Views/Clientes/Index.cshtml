@model IEnumerable<DriveNow.MVC.Models.ClienteView>

@{
    ViewData["Title"] = "Clientes";
}

<h1 class="fw-medium">Lista de Clientes</h1>

<p>
    <a class="btn btn-primary" asp-action="CriarCliente">Criar +</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cpf)
            </th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>@item.Email</td>
                <td>@item.Cpf</td>
                <td>
                    <a asp-action="EditarCliente" asp-route-id="@item.Id" class="btn btn-warning">Editar</a>

                    <a asp-action="DeletarCliente" asp-route-id="@item.Id" class="btn btn-danger">Deletar</a>
                </td>
            </tr>
        }
    </tbody>
</table>